{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sistema Angeline",
  "version": "1.0.0",
  "identifier": "com.angeline.sovereignledger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sistema Angeline — The Sovereign Ledger",
        "width": 1366,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
